local Alchemy = {}
Alchemy.__index = Alchemy

-- Services
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

-- Global State
local ValidInstances = {}
local Connections = {}

-- Utility Functions
local function GetGuiParent()
    local ok, gui = pcall(function() return gethui and gethui() end)
    if ok and gui then return gui end
    local ok2, core = pcall(function() return CoreGui end)
    if ok2 and core then return core end
    return Players.LocalPlayer:WaitForChild("PlayerGui")
end

local function Tween(instance, properties, duration, style, direction)
    local info = TweenInfo.new(duration or 0.2, style or Enum.EasingStyle.Quad, direction or Enum.EasingDirection.Out)
    local tween = TweenService:Create(instance, info, properties)
    tween:Play()
    return tween
end

local function Round(instance, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or 6)
    corner.Parent = instance
    return corner
end

local function AddConnection(conn)
    table.insert(Connections, conn)
    return conn
end

-- Cleanup Method
function Alchemy:Destroy()
    print("[Alchemy Lib] Cleaning up active instances...")
    
    -- Disconnect global events
    for _, conn in ipairs(Connections) do
        if conn and typeof(conn) == "RBXScriptConnection" and conn.Connected then
            conn:Disconnect()
        end
    end
    table.clear(Connections)

    -- Destroy UI instances
    for _, instance in ipairs(ValidInstances) do
        if instance and instance.Parent then
            instance:Destroy()
        end
    end
    table.clear(ValidInstances)
end

-- Notification System
function Alchemy:Notify(options)
    options = options or {}
    local Title = options.Title or "Notification"
    local Content = options.Content or "This is a notification."
    local Duration = options.Duration or 6.5
    local Color = options.Color or Color3.fromRGB(170, 60, 255)

    -- Detect or Create Notification Container
    local NotifGui = GetGuiParent():FindFirstChild("AlchemyNotifications")
    if not NotifGui then
        NotifGui = Instance.new("ScreenGui")
        NotifGui.Name = "AlchemyNotifications"
        NotifGui.ResetOnSpawn = false
        NotifGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        NotifGui.Parent = GetGuiParent()
        table.insert(ValidInstances, NotifGui)

        local Container = Instance.new("Frame")
        Container.Name = "Container"
        Container.Size = UDim2.new(0, 300, 1, -20)
        Container.Position = UDim2.new(1, -320, 0, 20)
        Container.BackgroundTransparency = 1
        Container.Parent = NotifGui

        local ListLayout = Instance.new("UIListLayout")
        ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
        ListLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
        ListLayout.Padding = UDim.new(0, 10)
        ListLayout.Parent = Container
    end

    local Container = NotifGui.Container

    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(1, 0, 0, 0) -- Starts collapsed
    Frame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    Frame.BackgroundTransparency = 0.1
    Frame.ClipsDescendants = true
    Frame.Parent = Container
    Round(Frame, 8)

    local Stroke = Instance.new("UIStroke")
    Stroke.Color = Color
    Stroke.Thickness = 1.5
    Stroke.Transparency = 0.5
    Stroke.Parent = Frame

    local TitleLbl = Instance.new("TextLabel")
    TitleLbl.Size = UDim2.new(1, -20, 0, 25)
    TitleLbl.Position = UDim2.new(0, 10, 0, 5)
    TitleLbl.BackgroundTransparency = 1
    TitleLbl.Text = Title
    TitleLbl.TextColor3 = Color
    TitleLbl.TextSize = 14
    TitleLbl.Font = Enum.Font.GothamBold
    TitleLbl.TextXAlignment = Enum.TextXAlignment.Left
    TitleLbl.Parent = Frame

    local ContentLbl = Instance.new("TextLabel")
    ContentLbl.Size = UDim2.new(1, -20, 1, -35)
    ContentLbl.Position = UDim2.new(0, 10, 0, 30)
    ContentLbl.BackgroundTransparency = 1
    ContentLbl.Text = Content
    ContentLbl.TextColor3 = Color3.fromRGB(220, 220, 220)
    ContentLbl.TextSize = 12
    ContentLbl.Font = Enum.Font.Gotham
    ContentLbl.TextWrapped = true
    ContentLbl.TextXAlignment = Enum.TextXAlignment.Left
    ContentLbl.TextYAlignment = Enum.TextYAlignment.Top
    ContentLbl.Parent = Frame

    -- Calculate best size (approximate)
    local reqHeight = 40 + (string.len(Content) / 40) * 15
    if reqHeight < 70 then reqHeight = 70 end

    -- Animate In
    Tween(Frame, {Size = UDim2.new(1, 0, 0, reqHeight)}, 0.4, Enum.EasingStyle.Back)
    
    -- Lifetime handler
    task.spawn(function()
        task.wait(Duration)
        if Frame and Frame.Parent then
            Tween(Frame, {Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1}, 0.3)
            task.wait(0.3)
            Frame:Destroy()
        end
    end)
end

-- Core Window Creation
function Alchemy:CreateWindow(options)
    options = options or {}
    local WindowName = options.Name or "Alchemy Hub"
    local WindowColor = options.Color or Color3.fromRGB(170, 60, 255)
    
    local Window = { Tabs = {}, CurrentTab = nil, Color = WindowColor }
    setmetatable(Window, Alchemy)

    local SecretName = HttpService:GenerateGUID(false)
    self:Destroy()

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = SecretName
    ScreenGui.ResetOnSpawn = false
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.Parent = GetGuiParent()
    table.insert(ValidInstances, ScreenGui)

    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "Main"
    MainFrame.Size = UDim2.new(0, 600, 0, 420)
    MainFrame.Position = UDim2.new(0.5, -300, 0.5, -210)
    MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
    MainFrame.BackgroundTransparency = 0.15
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = true
    MainFrame.Parent = ScreenGui
    Round(MainFrame, 8)

    local Stroke = Instance.new("UIStroke")
    Stroke.Color = Color3.fromRGB(255, 255, 255)
    Stroke.Transparency = 0.85
    Stroke.Parent = MainFrame

    local dragging, dragInput, dragStart, startPos
    AddConnection(MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end))
    AddConnection(MainFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end))
    AddConnection(UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end))

    local TitleBar = Instance.new("Frame")
    TitleBar.Size = UDim2.new(1, 0, 0, 40)
    TitleBar.BackgroundTransparency = 1
    TitleBar.Parent = MainFrame

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Size = UDim2.new(1, -20, 1, 0)
    TitleLabel.Position = UDim2.new(0, 15, 0, 0)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = WindowName
    TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    TitleLabel.TextSize = 16
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    TitleLabel.Parent = TitleBar

    local TitleGlow = Instance.new("UIGradient")
    TitleGlow.Color = ColorSequence.new({ ColorSequenceKeypoint.new(0, WindowColor), ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255)) })
    TitleGlow.Parent = TitleLabel
    
    local ButtonContainer = Instance.new("Frame")
    ButtonContainer.Size = UDim2.new(0, 140, 1, 0)
    ButtonContainer.Position = UDim2.new(1, -140, 0, 0)
    ButtonContainer.BackgroundTransparency = 1
    ButtonContainer.Parent = TitleBar

    local BtnLayout = Instance.new("UIListLayout")
    BtnLayout.FillDirection = Enum.FillDirection.Horizontal
    BtnLayout.HorizontalAlignment = Enum.HorizontalAlignment.Right
    BtnLayout.VerticalAlignment = Enum.VerticalAlignment.Center
    BtnLayout.Padding = UDim.new(0, 6)
    BtnLayout.Parent = ButtonContainer

    local BtnPadding = Instance.new("UIPadding")
    BtnPadding.PaddingRight = UDim.new(0, 10)
    BtnPadding.Parent = ButtonContainer

    local function CreateTopBtn(text, color, iconSize)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 26, 0, 26)
        btn.BackgroundColor3 = color
        btn.BackgroundTransparency = 0.2
        btn.Text = text
        btn.TextColor3 = Color3.fromRGB(220, 220, 220)
        btn.TextSize = iconSize or 12
        btn.Font = Enum.Font.GothamBold
        btn.Parent = ButtonContainer
        Round(btn, 6)
        
        local h, s, v = color:ToHSV()
        local hoverColor = Color3.fromHSV(h, s, math.clamp(v + 0.2, 0, 1))

        AddConnection(btn.MouseEnter:Connect(function() Tween(btn, {BackgroundColor3 = hoverColor, TextColor3 = Color3.fromRGB(255, 255, 255)}, 0.2) end))
        AddConnection(btn.MouseLeave:Connect(function() Tween(btn, {BackgroundColor3 = color, TextColor3 = Color3.fromRGB(220, 220, 220)}, 0.2) end))
        return btn
    end

    local BtnSettings = CreateTopBtn("⚙", Color3.fromRGB(40, 40, 50), 14)
    local BtnSearch   = CreateTopBtn("🔍", Color3.fromRGB(40, 40, 50), 12)
    local BtnMinimize = CreateTopBtn("-", Color3.fromRGB(40, 40, 50), 16)
    local BtnClose    = CreateTopBtn("X", Color3.fromRGB(120, 40, 50), 14)

    -- Search UI Implementation
    local SearchFrame = Instance.new("Frame")
    SearchFrame.Name = "SearchFrame"
    SearchFrame.Size = UDim2.new(1, -200, 0, 30)
    SearchFrame.Position = UDim2.new(0, 15, 0, 5)
    SearchFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 15)
    SearchFrame.BackgroundTransparency = 1
    SearchFrame.Visible = false
    SearchFrame.ClipsDescendants = true
    SearchFrame.Parent = TitleBar
    Round(SearchFrame, 6)

    local SearchBox = Instance.new("TextBox")
    SearchBox.Size = UDim2.new(1, -10, 1, 0)
    SearchBox.Position = UDim2.new(0, 5, 0, 0)
    SearchBox.BackgroundTransparency = 1
    SearchBox.PlaceholderText = "Search elements..."
    SearchBox.Text = ""
    SearchBox.TextColor3 = Window.Color
    SearchBox.PlaceholderColor3 = Color3.fromRGB(100, 100, 100)
    SearchBox.TextSize = 13
    SearchBox.Font = Enum.Font.Gotham
    SearchBox.TextXAlignment = Enum.TextXAlignment.Left
    SearchBox.Parent = SearchFrame

    local SearchUnderline = Instance.new("Frame")
    SearchUnderline.Size = UDim2.new(1, 0, 0, 2)
    SearchUnderline.Position = UDim2.new(0, 0, 1, -2)
    SearchUnderline.BackgroundColor3 = Window.Color
    SearchUnderline.BorderSizePixel = 0
    SearchUnderline.Parent = SearchFrame

    -- Search Logic
    local searchActive = false
    AddConnection(BtnSearch.MouseButton1Click:Connect(function()
        searchActive = not searchActive
        if searchActive then
            SearchFrame.Visible = true
            TitleLabel.Visible = false
            Tween(SearchFrame, {BackgroundTransparency = 0}, 0.2)
            SearchBox:CaptureFocus()
        else
            Tween(SearchFrame, {BackgroundTransparency = 1}, 0.2)
            task.wait(0.2)
            SearchFrame.Visible = false
            TitleLabel.Visible = true
            SearchBox.Text = ""
        end
    end))

    AddConnection(SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local query = SearchBox.Text:lower()
        local currentPage = nil
        
        -- Find current page
        for _, tab in pairs(Window.Tabs) do
            if tab.Page.Visible then
                currentPage = tab.Page
                break
            end
        end

        if currentPage then
            for _, child in ipairs(currentPage:GetChildren()) do
                if child:IsA("Frame") or child:IsA("TextButton") then
                    if child.Name == "UIListLayout" or child.Name == "UIPadding" then
                        -- Keep layout instances visible
                    elseif string.find(child.Name:lower(), query) then
                        child.Visible = true
                    else
                        child.Visible = false
                    end
                end
            end
        end
    end))

    AddConnection(BtnClose.MouseButton1Click:Connect(function()
        Tween(MainFrame, {Size = UDim2.new(0, 600, 0, 0), BackgroundTransparency = 1}, 0.3)
        task.wait(0.3)
        self:Destroy()
    end))

    local minimized = false
    AddConnection(BtnMinimize.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then Tween(MainFrame, {Size = UDim2.new(0, 600, 0, 40)}, 0.3, Enum.EasingStyle.Exponential)
        else Tween(MainFrame, {Size = UDim2.new(0, 600, 0, 420)}, 0.3, Enum.EasingStyle.Exponential) end
    end))

    Window.SettingsButton = BtnSettings
    Window.SearchButton = BtnSearch
    
    -- Auto-Settings Tab Creation
    local SettingsTab = Window:CreateTab({Name = "Settings"})
    local SettingsSection = SettingsTab:CreateSection("Library Settings")
    SettingsSection:CreateButton({
        Name = "Destroy UI",
        Callback = function() self:Destroy() end
    })

    AddConnection(BtnSettings.MouseButton1Click:Connect(function()
        -- Trigger tab selection for settings
        for _, tab in pairs(Window.Tabs) do
            if tab.Button.Text == "  Settings" then
                -- Manually trigger the click connection logic
                for _, t in pairs(Window.Tabs) do
                    t.Page.Visible = false
                    Tween(t.Button, {BackgroundTransparency = 0.95, TextColor3 = Color3.fromRGB(180, 180, 180)}, 0.2)
                end
                tab.Page.Visible = true
                Tween(tab.Button, {BackgroundTransparency = 0.8, TextColor3 = Window.Color}, 0.2)
                Window.CurrentTab = "Settings"
                break
            end
        end
    end))

    local Sidebar = Instance.new("Frame")
    Sidebar.Size = UDim2.new(0, 150, 1, -40)
    Sidebar.Position = UDim2.new(0, 0, 0, 40)
    Sidebar.BackgroundColor3 = Color3.fromRGB(10, 10, 15)
    Sidebar.BackgroundTransparency = 0.5
    Sidebar.BorderSizePixel = 0
    Sidebar.Parent = MainFrame

    local TabList = Instance.new("UIListLayout")
    TabList.SortOrder = Enum.SortOrder.LayoutOrder
    TabList.Padding = UDim.new(0, 5)
    TabList.Parent = Sidebar

    local SidebarPadding = Instance.new("UIPadding")
    SidebarPadding.PaddingTop = UDim.new(0, 10)
    SidebarPadding.PaddingLeft = UDim.new(0, 10)
    SidebarPadding.PaddingRight = UDim.new(0, 10)
    SidebarPadding.Parent = Sidebar

    local ContentContainer = Instance.new("Frame")
    ContentContainer.Size = UDim2.new(1, -150, 1, -40)
    ContentContainer.Position = UDim2.new(0, 150, 0, 40)
    ContentContainer.BackgroundTransparency = 1
    ContentContainer.Parent = MainFrame

    function Window:CreateTab(options)
        local TabName = options.Name or "Tab"
        
        local TabButton = Instance.new("TextButton")
        TabButton.Size = UDim2.new(1, 0, 0, 32)
        TabButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        TabButton.BackgroundTransparency = 0.95
        TabButton.Text = "  " .. TabName
        TabButton.TextColor3 = Color3.fromRGB(180, 180, 180)
        TabButton.TextSize = 13
        TabButton.Font = Enum.Font.GothamMedium
        TabButton.TextXAlignment = Enum.TextXAlignment.Left
        TabButton.Parent = Sidebar
        Round(TabButton, 6)

        local TabPage = Instance.new("ScrollingFrame")
        TabPage.Size = UDim2.new(1, 0, 1, 0)
        TabPage.BackgroundTransparency = 1
        TabPage.ScrollBarThickness = 2
        TabPage.ScrollBarImageColor3 = Window.Color
        TabPage.Visible = false
        TabPage.Parent = ContentContainer

        local PageList = Instance.new("UIListLayout")
        PageList.SortOrder = Enum.SortOrder.LayoutOrder
        PageList.Padding = UDim.new(0, 8)
        PageList.Parent = TabPage

        local PagePadding = Instance.new("UIPadding")
        PagePadding.PaddingTop = UDim.new(0, 10)
        PagePadding.PaddingLeft = UDim.new(0, 15)
        PagePadding.PaddingRight = UDim.new(0, 15)
        PagePadding.PaddingBottom = UDim.new(0, 10)
        PagePadding.Parent = TabPage

        AddConnection(PageList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            TabPage.CanvasSize = UDim2.new(0, 0, 0, PageList.AbsoluteContentSize.Y + 20)
        end))

        AddConnection(TabButton.MouseButton1Click:Connect(function()
            for _, tab in pairs(Window.Tabs) do
                tab.Page.Visible = false
                Tween(tab.Button, {BackgroundTransparency = 0.95, TextColor3 = Color3.fromRGB(180, 180, 180)}, 0.2)
            end
            TabPage.Visible = true
            Tween(TabButton, {BackgroundTransparency = 0.8, TextColor3 = Window.Color}, 0.2)
            Window.CurrentTab = TabName
        end))

        if not Window.CurrentTab then
            TabPage.Visible = true
            TabButton.BackgroundTransparency = 0.8
            TabButton.TextColor3 = Window.Color
            Window.CurrentTab = TabName
        end

        local TabData = { Button = TabButton, Page = TabPage }
        table.insert(Window.Tabs, TabData)

        local Tab = {}
        function Tab:CreateSection(sectionName)
            local SectionLabel = Instance.new("TextLabel")
            SectionLabel.Size = UDim2.new(1, 0, 0, 20)
            SectionLabel.BackgroundTransparency = 1
            SectionLabel.Text = sectionName:upper()
            SectionLabel.TextColor3 = Window.Color
            SectionLabel.TextSize = 12
            SectionLabel.Font = Enum.Font.GothamBold
            SectionLabel.TextXAlignment = Enum.TextXAlignment.Left
            SectionLabel.Parent = TabPage

            local Section = {}
            
            -- PARAGRAPH
            function Section:CreateParagraph(opts)
                local Title = opts.Title or "Paragraph"
                local Content = opts.Content or "Content here."

                local ParaFrame = Instance.new("Frame")
                ParaFrame.Name = Title
                ParaFrame.Size = UDim2.new(1, 0, 0, 60)
                ParaFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
                ParaFrame.BackgroundTransparency = 0.4
                ParaFrame.Parent = TabPage
                Round(ParaFrame, 6)

                local TitleLbl = Instance.new("TextLabel")
                TitleLbl.Size = UDim2.new(1, -20, 0, 20)
                TitleLbl.Position = UDim2.new(0, 10, 0, 5)
                TitleLbl.BackgroundTransparency = 1
                TitleLbl.Text = Title
                TitleLbl.TextColor3 = Window.Color
                TitleLbl.TextSize = 13
                TitleLbl.Font = Enum.Font.GothamBold
                TitleLbl.TextXAlignment = Enum.TextXAlignment.Left
                TitleLbl.Parent = ParaFrame

                local ContentLbl = Instance.new("TextLabel")
                ContentLbl.Size = UDim2.new(1, -20, 1, -30)
                ContentLbl.Position = UDim2.new(0, 10, 0, 25)
                ContentLbl.BackgroundTransparency = 1
                ContentLbl.Text = Content
                ContentLbl.TextColor3 = Color3.fromRGB(180, 180, 180)
                ContentLbl.TextSize = 12
                ContentLbl.Font = Enum.Font.Gotham
                ContentLbl.TextWrapped = true
                ContentLbl.TextXAlignment = Enum.TextXAlignment.Left
                ContentLbl.TextYAlignment = Enum.TextYAlignment.Top
                ContentLbl.Parent = ParaFrame
                
                -- Auto adjust height
                local reqHeight = 35 + (string.len(Content) / 45) * 15
                ParaFrame.Size = UDim2.new(1, 0, 0, math.max(60, reqHeight))
                
                return {
                    Set = function(newOpts)
                        if newOpts.Title then TitleLbl.Text = newOpts.Title end
                        if newOpts.Content then 
                            ContentLbl.Text = newOpts.Content
                            local nH = 35 + (string.len(newOpts.Content) / 45) * 15
                            Tween(ParaFrame, {Size = UDim2.new(1, 0, 0, math.max(60, nH))}, 0.2)
                        end
                    end
                }
            end

            -- BUTTON
            function Section:CreateButton(opts)
                local btnName = opts.Name or "Button"
                local callback = opts.Callback or function() end

                local BtnFrame = Instance.new("TextButton")
                BtnFrame.Name = btnName
                BtnFrame.Size = UDim2.new(1, 0, 0, 36)
                BtnFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
                BtnFrame.BackgroundTransparency = 0.4
                BtnFrame.Text = btnName
                BtnFrame.TextColor3 = Color3.fromRGB(220, 220, 220)
                BtnFrame.TextSize = 13
                BtnFrame.Font = Enum.Font.Gotham
                BtnFrame.Parent = TabPage
                Round(BtnFrame, 6)

                local s = Instance.new("UIStroke")
                s.Color = Color3.fromRGB(40, 40, 50)
                s.Parent = BtnFrame

                AddConnection(BtnFrame.MouseEnter:Connect(function()
                    Tween(BtnFrame, {BackgroundColor3 = Color3.fromRGB(30, 30, 35)}, 0.2)
                    Tween(s, {Color = Window.Color}, 0.2)
                end))
                AddConnection(BtnFrame.MouseLeave:Connect(function()
                    Tween(BtnFrame, {BackgroundColor3 = Color3.fromRGB(20, 20, 25)}, 0.2)
                    Tween(s, {Color = Color3.fromRGB(40, 40, 50)}, 0.2)
                end))

                AddConnection(BtnFrame.MouseButton1Click:Connect(function()
                    Tween(BtnFrame, {Size = UDim2.new(1, -4, 0, 32)}, 0.1)
                    task.wait(0.1)
                    Tween(BtnFrame, {Size = UDim2.new(1, 0, 0, 36)}, 0.1)
                    callback()
                end))
            end

            -- KEYBIND
            function Section:CreateKeybind(opts)
                local kName = opts.Name or "Keybind"
                local currentKey = opts.CurrentKey or Enum.KeyCode.E
                local callback = opts.Callback or function() end

                local KeyHolder = Instance.new("Frame")
                KeyHolder.Name = kName
                KeyHolder.Size = UDim2.new(1, 0, 0, 36)
                KeyHolder.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
                KeyHolder.BackgroundTransparency = 0.4
                KeyHolder.Parent = TabPage
                Round(KeyHolder, 6)

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -100, 1, 0)
                Label.Position = UDim2.new(0, 10, 0, 0)
                Label.BackgroundTransparency = 1
                Label.Text = kName
                Label.TextColor3 = Color3.fromRGB(220, 220, 220)
                Label.TextSize = 13
                Label.Font = Enum.Font.Gotham
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = KeyHolder

                local BindBtn = Instance.new("TextButton")
                BindBtn.Size = UDim2.new(0, 80, 0, 24)
                BindBtn.Position = UDim2.new(1, -90, 0.5, -12)
                BindBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
                BindBtn.Text = currentKey.Name
                BindBtn.TextColor3 = Window.Color
                BindBtn.TextSize = 12
                BindBtn.Font = Enum.Font.GothamBold
                BindBtn.Parent = KeyHolder
                Round(BindBtn, 4)

                local IsBinding = false

                AddConnection(BindBtn.MouseButton1Click:Connect(function()
                    IsBinding = true
                    BindBtn.Text = "..."
                    Tween(BindBtn, {BackgroundColor3 = Color3.fromRGB(60, 60, 70)}, 0.2)
                end))

                AddConnection(UserInputService.InputBegan:Connect(function(input, gameProcessed)
                    if not gameProcessed then
                        if IsBinding and input.UserInputType == Enum.UserInputType.Keyboard then
                            currentKey = input.KeyCode
                            BindBtn.Text = currentKey.Name
                            Tween(BindBtn, {BackgroundColor3 = Color3.fromRGB(40, 40, 50)}, 0.2)
                            IsBinding = false
                        elseif not IsBinding and input.KeyCode == currentKey then
                            callback(currentKey.Name)
                        end
                    end
                end))
                
                return {
                    Set = function(key)
                        currentKey = typeof(key) == "EnumItem" and key or Enum.KeyCode[key]
                        BindBtn.Text = currentKey.Name
                    end
                }
            end

            -- INPUT (TextBox)
            function Section:CreateInput(opts)
                local iName = opts.Name or "Input"
                local placeHolder = opts.PlaceholderText or "Type here..."
                local callback = opts.Callback or function() end

                local InpHolder = Instance.new("Frame")
                InpHolder.Name = iName
                InpHolder.Size = UDim2.new(1, 0, 0, 46)
                InpHolder.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
                InpHolder.BackgroundTransparency = 0.4
                InpHolder.Parent = TabPage
                Round(InpHolder, 6)

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -10, 0, 20)
                Label.Position = UDim2.new(0, 10, 0, 2)
                Label.BackgroundTransparency = 1
                Label.Text = iName
                Label.TextColor3 = Color3.fromRGB(220, 220, 220)
                Label.TextSize = 12
                Label.Font = Enum.Font.Gotham
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = InpHolder

                local BoxBG = Instance.new("Frame")
                BoxBG.Size = UDim2.new(1, -20, 0, 20)
                BoxBG.Position = UDim2.new(0, 10, 0, 22)
                BoxBG.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
                BoxBG.Parent = InpHolder
                Round(BoxBG, 4)
                local stroke = Instance.new("UIStroke", BoxBG)
                stroke.Color = Color3.fromRGB(50, 50, 60)

                local TextBox = Instance.new("TextBox")
                TextBox.Size = UDim2.new(1, -10, 1, 0)
                TextBox.Position = UDim2.new(0, 5, 0, 0)
                TextBox.BackgroundTransparency = 1
                TextBox.Text = ""
                TextBox.PlaceholderText = placeHolder
                TextBox.TextColor3 = Window.Color
                TextBox.PlaceholderColor3 = Color3.fromRGB(100, 100, 100)
                TextBox.TextSize = 12
                TextBox.Font = Enum.Font.Gotham
                TextBox.TextXAlignment = Enum.TextXAlignment.Left
                TextBox.ClearTextOnFocus = false
                TextBox.Parent = BoxBG

                AddConnection(TextBox.FocusLost:Connect(function(enterPressed)
                    if enterPressed then
                        callback(TextBox.Text)
                        Tween(stroke, {Color = Window.Color}, 0.1)
                        task.wait(0.2)
                        Tween(stroke, {Color = Color3.fromRGB(50, 50, 60)}, 0.3)
                    end
                end))
            end

            -- DROPDOWN
            function Section:CreateDropdown(opts)
                local dName = opts.Name or "Dropdown"
                local options = opts.Options or {"Option 1", "Option 2"}
                local current = opts.CurrentOption or options[1]
                local callback = opts.Callback or function() end

                local DropHolder = Instance.new("Frame")
                DropHolder.Name = dName
                DropHolder.Size = UDim2.new(1, 0, 0, 36)
                DropHolder.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
                DropHolder.BackgroundTransparency = 0.4
                DropHolder.ClipsDescendants = true
                DropHolder.Parent = TabPage
                Round(DropHolder, 6)

                local MainBtn = Instance.new("TextButton")
                MainBtn.Size = UDim2.new(1, 0, 0, 36)
                MainBtn.BackgroundTransparency = 1
                MainBtn.Text = ""
                MainBtn.Parent = DropHolder

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -150, 1, 0)
                Label.Position = UDim2.new(0, 10, 0, 0)
                Label.BackgroundTransparency = 1
                Label.Text = dName
                Label.TextColor3 = Color3.fromRGB(220, 220, 220)
                Label.TextSize = 13
                Label.Font = Enum.Font.Gotham
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = MainBtn

                local SelectBox = Instance.new("Frame")
                SelectBox.Size = UDim2.new(0, 120, 0, 24)
                SelectBox.Position = UDim2.new(1, -130, 0.5, -12)
                SelectBox.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
                SelectBox.Parent = MainBtn
                Round(SelectBox, 4)

                local SelectLabel = Instance.new("TextLabel")
                SelectLabel.Size = UDim2.new(1, -5, 1, 0)
                SelectLabel.BackgroundTransparency = 1
                SelectLabel.Text = tostring(current)
                SelectLabel.TextColor3 = Window.Color
                SelectLabel.TextSize = 12
                SelectLabel.Font = Enum.Font.GothamBold
                SelectLabel.Parent = SelectBox

                local ItemsContainer = Instance.new("Frame")
                ItemsContainer.Size = UDim2.new(1, -20, 0, 0) -- Grows dynamically
                ItemsContainer.Position = UDim2.new(0, 10, 0, 36)
                ItemsContainer.BackgroundTransparency = 1
                ItemsContainer.Parent = DropHolder

                local ItemList = Instance.new("UIListLayout")
                ItemList.SortOrder = Enum.SortOrder.LayoutOrder
                ItemList.Padding = UDim.new(0, 4)
                ItemList.Parent = ItemsContainer

                local IsOpen = false
                local OptionBtns = {}

                local function PopulateOptions(optsList)
                    for _, old in ipairs(OptionBtns) do old:Destroy() end
                    OptionBtns = {}
                    
                    for i, opt in ipairs(optsList) do
                        local optBtn = Instance.new("TextButton")
                        optBtn.Size = UDim2.new(1, 0, 0, 26)
                        optBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
                        optBtn.Text = tostring(opt)
                        optBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
                        optBtn.TextSize = 12
                        optBtn.Font = Enum.Font.Gotham
                        optBtn.Parent = ItemsContainer
                        Round(optBtn, 4)
                        table.insert(OptionBtns, optBtn)

                        AddConnection(optBtn.MouseButton1Click:Connect(function()
                            current = opt
                            SelectLabel.Text = tostring(opt)
                            callback(opt)
                            IsOpen = false
                            Tween(DropHolder, {Size = UDim2.new(1, 0, 0, 36)}, 0.3, Enum.EasingStyle.Exponential)
                        end))
                    end
                end

                PopulateOptions(options)

                AddConnection(MainBtn.MouseButton1Click:Connect(function()
                    IsOpen = not IsOpen
                    if IsOpen then
                        local requiredSize = 36 + (26 * #options) + (4 * #options) + 10
                        Tween(DropHolder, {Size = UDim2.new(1, 0, 0, requiredSize)}, 0.3, Enum.EasingStyle.Exponential)
                    else
                        Tween(DropHolder, {Size = UDim2.new(1, 0, 0, 36)}, 0.3, Enum.EasingStyle.Exponential)
                    end
                end))

                return {
                    Set = function(val)
                        current = val
                        SelectLabel.Text = tostring(val)
                        callback(val)
                    end,
                    Refresh = function(newOptions)
                        PopulateOptions(newOptions)
                        if IsOpen then
                            local reqSize = 36 + (26 * #newOptions) + (4 * #newOptions) + 10
                            Tween(DropHolder, {Size = UDim2.new(1, 0, 0, reqSize)}, 0.3)
                        end
                    end
                }
            end

            -- TOGGLE
            function Section:CreateToggle(opts)
                local tName = opts.Name or "Toggle"
                local state = opts.Default or false
                local callback = opts.Callback or function() end

                local TglHolder = Instance.new("Frame")
                TglHolder.Name = tName
                TglHolder.Size = UDim2.new(1, 0, 0, 36)
                TglHolder.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
                TglHolder.BackgroundTransparency = 0.4
                TglHolder.Parent = TabPage
                Round(TglHolder, 6)

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -60, 1, 0)
                Label.Position = UDim2.new(0, 10, 0, 0)
                Label.BackgroundTransparency = 1
                Label.Text = tName
                Label.TextColor3 = Color3.fromRGB(220, 220, 220)
                Label.TextSize = 13
                Label.Font = Enum.Font.Gotham
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = TglHolder

                local SwitchBG = Instance.new("Frame")
                SwitchBG.Size = UDim2.new(0, 40, 0, 20)
                SwitchBG.Position = UDim2.new(1, -50, 0.5, -10)
                SwitchBG.BackgroundColor3 = state and Window.Color or Color3.fromRGB(40, 40, 50)
                SwitchBG.Parent = TglHolder
                Round(SwitchBG, 10)

                local Knob = Instance.new("Frame")
                Knob.Size = UDim2.new(0, 16, 0, 16)
                Knob.Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
                Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                Knob.Parent = SwitchBG
                Round(Knob, 8)

                local Btn = Instance.new("TextButton")
                Btn.Size = UDim2.new(1, 0, 1, 0)
                Btn.BackgroundTransparency = 1
                Btn.Text = ""
                Btn.Parent = TglHolder

                AddConnection(Btn.MouseButton1Click:Connect(function()
                    state = not state
                    Tween(SwitchBG, {BackgroundColor3 = state and Window.Color or Color3.fromRGB(40, 40, 50)}, 0.2)
                    Tween(Knob, {Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)}, 0.2, Enum.EasingStyle.Back)
                    callback(state)
                end))

                return {
                    Set = function(val)
                        state = val
                        Tween(SwitchBG, {BackgroundColor3 = state and Window.Color or Color3.fromRGB(40, 40, 50)}, 0.2)
                        Tween(Knob, {Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)}, 0.2, Enum.EasingStyle.Back)
                        callback(state)
                    end,
                    Get = function() return state end
                }
            end

            -- SLIDER
            function Section:CreateSlider(opts)
                local sName = opts.Name or "Slider"
                local sMin = opts.Min or 0
                local sMax = opts.Max or 100
                local sDef = opts.Default or 50
                local callback = opts.Callback or function() end

                local SldrHolder = Instance.new("Frame")
                SldrHolder.Name = sName
                SldrHolder.Size = UDim2.new(1, 0, 0, 50)
                SldrHolder.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
                SldrHolder.BackgroundTransparency = 0.4
                SldrHolder.Parent = TabPage
                Round(SldrHolder, 6)

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -60, 0, 24)
                Label.Position = UDim2.new(0, 10, 0, 0)
                Label.BackgroundTransparency = 1
                Label.Text = sName
                Label.TextColor3 = Color3.fromRGB(220, 220, 220)
                Label.TextSize = 13
                Label.Font = Enum.Font.Gotham
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = SldrHolder

                local ValueLabel = Instance.new("TextLabel")
                ValueLabel.Size = UDim2.new(0, 50, 0, 24)
                ValueLabel.Position = UDim2.new(1, -60, 0, 0)
                ValueLabel.BackgroundTransparency = 1
                ValueLabel.Text = tostring(sDef)
                ValueLabel.TextColor3 = Window.Color
                ValueLabel.TextSize = 13
                ValueLabel.Font = Enum.Font.GothamBold
                ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
                ValueLabel.Parent = SldrHolder

                local TrackBG = Instance.new("Frame")
                TrackBG.Size = UDim2.new(1, -20, 0, 6)
                TrackBG.Position = UDim2.new(0, 10, 0, 32)
                TrackBG.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
                TrackBG.Parent = SldrHolder
                Round(TrackBG, 3)

                local Fill = Instance.new("Frame")
                local pct = math.clamp((sDef - sMin) / (sMax - sMin), 0, 1)
                Fill.Size = UDim2.new(pct, 0, 1, 0)
                Fill.BackgroundColor3 = Window.Color
                Fill.Parent = TrackBG
                Round(Fill, 3)

                local DragBtn = Instance.new("TextButton")
                DragBtn.Size = UDim2.new(1, 0, 1, 20)
                DragBtn.Position = UDim2.new(0, 0, 0, -10)
                DragBtn.BackgroundTransparency = 1
                DragBtn.Text = ""
                DragBtn.Parent = TrackBG

                local dragging = false
                AddConnection(DragBtn.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                    end
                end))

                AddConnection(UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                    end
                end))

                local function updateSlider(input)
                    local pos = math.clamp((input.Position.X - TrackBG.AbsolutePosition.X) / TrackBG.AbsoluteSize.X, 0, 1)
                    local value = math.floor(sMin + ((sMax - sMin) * pos))
                    Tween(Fill, {Size = UDim2.new(pos, 0, 1, 0)}, 0.1)
                    ValueLabel.Text = tostring(value)
                    callback(value)
                end

                AddConnection(UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        updateSlider(input)
                    end
                end))
                
                return {
                    Set = function(val)
                        local pos = math.clamp((val - sMin) / (sMax - sMin), 0, 1)
                        Tween(Fill, {Size = UDim2.new(pos, 0, 1, 0)}, 0.1)
                        ValueLabel.Text = tostring(val)
                        callback(val)
                    end
                }
            end
            
            function Section:CreateLabel(txt)
                local lbl = Instance.new("TextLabel")
                lbl.Name = "Label_" .. txt
                lbl.Size = UDim2.new(1, 0, 0, 20)
                lbl.BackgroundTransparency = 1
                lbl.Text = txt
                lbl.TextColor3 = Color3.fromRGB(150, 150, 150)
                lbl.TextSize = 12
                lbl.Font = Enum.Font.Gotham
                lbl.TextXAlignment = Enum.TextXAlignment.Left
                lbl.Parent = TabPage
                
                return { Set = function(newTxt) lbl.Text = newTxt end }
            end

            return Section
        end
        return Tab
    end
    return Window
end

return Alchemy
