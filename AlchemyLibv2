            function Section:CreateInput(opts)
                local iName = opts.Name or "Input"
                local placeHolder = opts.PlaceholderText or "Type here..."
                local callback = opts.Callback or function() end

                local InpHolder = Instance.new("Frame")
                InpHolder.Name = iName
                InpHolder.Size = UDim2.new(1, 0, 0, 55)
                InpHolder.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
                InpHolder.Parent = TabPage
                Round(InpHolder, 8)
                
                local istroke = Instance.new("UIStroke", InpHolder)
                istroke.Color = Color3.fromRGB(255, 255, 255)
                istroke.Transparency = 0.9

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -20, 0, 25)
                Label.Position = UDim2.new(0, 15, 0, 5)
                Label.BackgroundTransparency = 1
                Label.Text = iName
                Label.TextColor3 = Color3.fromRGB(230, 230, 230)
                Label.TextSize = 13
                Label.Font = Enum.Font.GothamMedium
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = InpHolder

                local BoxBG = Instance.new("Frame")
                BoxBG.Size = UDim2.new(1, -30, 0, 24)
                BoxBG.Position = UDim2.new(0, 15, 0, 26)
                BoxBG.BackgroundColor3 = Color3.fromRGB(10, 10, 12)
                BoxBG.Parent = InpHolder
                Round(BoxBG, 6)
                
                local stroke = Instance.new("UIStroke", BoxBG)
                stroke.Color = Color3.fromRGB(50, 50, 60)
                stroke.Transparency = 0.5

                local TextBox = Instance.new("TextBox")
                TextBox.Size = UDim2.new(1, -10, 1, 0)
                TextBox.Position = UDim2.new(0, 5, 0, 0)
                TextBox.BackgroundTransparency = 1
                TextBox.Text = ""
                TextBox.PlaceholderText = placeHolder
                TextBox.TextColor3 = WindowColor
                TextBox.PlaceholderColor3 = Color3.fromRGB(80, 80, 80)
                TextBox.TextSize = 12
                TextBox.Font = Enum.Font.Gotham
                TextBox.TextXAlignment = Enum.TextXAlignment.Left
                TextBox.ClearTextOnFocus = false
                TextBox.Parent = BoxBG

                AddConnection(TextBox.FocusLost:Connect(function(enterPressed)
                    if enterPressed then
                        callback(TextBox.Text)
                        Tween(stroke, {Color = WindowColor, Transparency = 0}, 0.1)
                        task.wait(0.2)
                        Tween(stroke, {Color = Color3.fromRGB(50, 50, 60), Transparency = 0.5}, 0.3)
                    end
                end))
            end

            -- DROPDOWN
            function Section:CreateDropdown(opts)
                local dName = opts.Name or "Dropdown"
                local options = opts.Options or {"Option 1", "Option 2"}
                local current = opts.CurrentOption or options[1]
                local callback = opts.Callback or function() end

                local DropHolder = Instance.new("Frame")
                DropHolder.Name = dName
                DropHolder.Size = UDim2.new(1, 0, 0, 45)
                DropHolder.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
                DropHolder.ClipsDescendants = true
                DropHolder.Parent = TabPage
                Round(DropHolder, 8)
                
                local dstroke = Instance.new("UIStroke", DropHolder)
                dstroke.Color = Color3.fromRGB(255, 255, 255)
                dstroke.Transparency = 0.9

                local MainBtn = Instance.new("TextButton")
                MainBtn.Size = UDim2.new(1, 0, 0, 45)
                MainBtn.BackgroundTransparency = 1
                MainBtn.Text = ""
                MainBtn.Parent = DropHolder

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -160, 1, 0)
                Label.Position = UDim2.new(0, 15, 0, 0)
                Label.BackgroundTransparency = 1
                Label.Text = dName
                Label.TextColor3 = Color3.fromRGB(230, 230, 230)
                Label.TextSize = 13
                Label.Font = Enum.Font.GothamMedium
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = MainBtn

                local SelectBox = Instance.new("Frame")
                SelectBox.Size = UDim2.new(0, 130, 0, 28)
                SelectBox.Position = UDim2.new(1, -145, 0.5, -14)
                SelectBox.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
                SelectBox.Parent = MainBtn
                Round(SelectBox, 6)
                
                local sstroke = Instance.new("UIStroke", SelectBox)
                sstroke.Color = WindowColor
                sstroke.Transparency = 0.8

                local SelectLabel = Instance.new("TextLabel")
                SelectLabel.Size = UDim2.new(1, -10, 1, 0)
                SelectLabel.BackgroundTransparency = 1
                SelectLabel.Text = tostring(current)
                SelectLabel.TextColor3 = WindowColor
                SelectLabel.TextSize = 12
                SelectLabel.Font = Enum.Font.GothamBold
                SelectLabel.Parent = SelectBox

                local ItemsContainer = Instance.new("Frame")
                ItemsContainer.Size = UDim2.new(1, -30, 0, 0)
                ItemsContainer.Position = UDim2.new(0, 15, 0, 45)
                ItemsContainer.BackgroundTransparency = 1
                ItemsContainer.Parent = DropHolder

                local ItemList = Instance.new("UIListLayout")
                ItemList.SortOrder = Enum.SortOrder.LayoutOrder
                ItemList.Padding = UDim.new(0, 5)
                ItemList.Parent = ItemsContainer

                local IsOpen = false
                local OptionBtns = {}

                local function PopulateOptions(optsList)
                    for _, old in ipairs(OptionBtns) do old:Destroy() end
                    table.clear(OptionBtns)
                    
                    for i, opt in ipairs(optsList) do
                        local optBtn = Instance.new("TextButton")
                        optBtn.Size = UDim2.new(1, 0, 0, 30)
                        optBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
                        optBtn.Text = tostring(opt)
                        optBtn.TextColor3 = opt == current and WindowColor or Color3.fromRGB(180, 180, 180)
                        optBtn.TextSize = 12
                        optBtn.Font = Enum.Font.Gotham
                        optBtn.Parent = ItemsContainer
                        Round(optBtn, 6)
                        table.insert(OptionBtns, optBtn)

                        AddConnection(optBtn.MouseButton1Click:Connect(function()
                            current = opt
                            SelectLabel.Text = tostring(opt)
                            callback(opt)
                            IsOpen = false
                            Tween(DropHolder, {Size = UDim2.new(1, 0, 0, 45)}, 0.3, Enum.EasingStyle.Exponential)
                        end))
                    end
                end

                PopulateOptions(options)

                AddConnection(MainBtn.MouseButton1Click:Connect(function()
                    IsOpen = not IsOpen
                    if IsOpen then
                        local requiredSize = 45 + (35 * #options) + 10
                        Tween(DropHolder, {Size = UDim2.new(1, 0, 0, requiredSize)}, 0.3, Enum.EasingStyle.Exponential)
                        Tween(sstroke, {Transparency = 0.3}, 0.2)
                    else
                        Tween(DropHolder, {Size = UDim2.new(1, 0, 0, 45)}, 0.3, Enum.EasingStyle.Exponential)
                        Tween(sstroke, {Transparency = 0.8}, 0.2)
                    end
                end))

                return {
                    Set = function(val)
                        current = val
                        SelectLabel.Text = tostring(val)
                        callback(val)
                        PopulateOptions(options)
                    end,
                    Refresh = function(newOptions)
                        options = newOptions
                        PopulateOptions(newOptions)
                        if IsOpen then
                            local reqSize = 45 + (35 * #newOptions) + 10
                            Tween(DropHolder, {Size = UDim2.new(1, 0, 0, reqSize)}, 0.3)
                        end
                    end
                }
            end


            -- SLIDER
            function Section:CreateSlider(opts)
                local sName = opts.Name or "Slider"
                local sMin = opts.Min or 0
                local sMax = opts.Max or 100
                local sDef = opts.Default or 50
                local callback = opts.Callback or function() end

                local SldrHolder = Instance.new("Frame")
                SldrHolder.Name = sName
                SldrHolder.Size = UDim2.new(1, 0, 0, 60)
                SldrHolder.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
                SldrHolder.Parent = TabPage
                Round(SldrHolder, 8)
                
                local sstroke = Instance.new("UIStroke", SldrHolder)
                sstroke.Color = Color3.fromRGB(255, 255, 255)
                sstroke.Transparency = 0.9

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -70, 0, 30)
                Label.Position = UDim2.new(0, 15, 0, 5)
                Label.BackgroundTransparency = 1
                Label.Text = sName
                Label.TextColor3 = Color3.fromRGB(230, 230, 230)
                Label.TextSize = 13
                Label.Font = Enum.Font.GothamMedium
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = SldrHolder

                local ValueLabel = Instance.new("TextLabel")
                ValueLabel.Size = UDim2.new(0, 50, 0, 30)
                ValueLabel.Position = UDim2.new(1, -65, 0, 5)
                ValueLabel.BackgroundTransparency = 1
                ValueLabel.Text = tostring(sDef)
                ValueLabel.TextColor3 = WindowColor
                ValueLabel.TextSize = 13
                ValueLabel.Font = Enum.Font.GothamBold
                ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
                ValueLabel.Parent = SldrHolder

                local SliderBG = Instance.new("Frame")
                SliderBG.Size = UDim2.new(1, -30, 0, 6)
                SliderBG.Position = UDim2.new(0, 15, 0, 40)
                SliderBG.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
                SliderBG.Parent = SldrHolder
                Round(SliderBG, 3)

                local SliderFill = Instance.new("Frame")
                SliderFill.Size = UDim2.new((sDef - sMin) / (sMax - sMin), 0, 1, 0)
                SliderFill.BackgroundColor3 = WindowColor
                SliderFill.Parent = SliderBG
                Round(SliderFill, 3)

                local SliderBtn = Instance.new("TextButton")
                SliderBtn.Size = UDim2.new(1, 0, 1, 0)
                SliderBtn.BackgroundTransparency = 1
                SliderBtn.Text = ""
                SliderBtn.Parent = SliderBG

                local function UpdateSlider()
                    local mousePos = UserInputService:GetMouseLocation().X
                    local bgPos = SliderBG.AbsolutePosition.X
                    local bgSize = SliderBG.AbsoluteSize.X
                    local perc = math.clamp((mousePos - bgPos) / bgSize, 0, 1)
                    local val = math.floor(sMin + (perc * (sMax - sMin)))
                    
                    Tween(SliderFill, {Size = UDim2.new(perc, 0, 1, 0)}, 0.1)
                    ValueLabel.Text = tostring(val)
                    callback(val)
                end

                local sliding = false
                AddConnection(SliderBtn.MouseButton1Down:Connect(function() 
                    sliding = true 
                    UpdateSlider() 
                end))
                AddConnection(UserInputService.InputEnded:Connect(function(input) 
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end 
                end))
                AddConnection(UserInputService.InputChanged:Connect(function(input)
                    if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then UpdateSlider() end
                end))
                
                return {
                    Set = function(val)
                        local perc = math.clamp((val - sMin) / (sMax - sMin), 0, 1)
                        Tween(SliderFill, {Size = UDim2.new(perc, 0, 1, 0)}, 0.1)
                        ValueLabel.Text = tostring(val)
                        callback(val)
                    end
                }
            end
            
            function Section:CreateLabel(txt)
                local lbl = Instance.new("TextLabel")
                lbl.Name = "Label_" .. txt
                lbl.Size = UDim2.new(1, 0, 0, 25)
                lbl.BackgroundTransparency = 1
                lbl.Text = txt
                lbl.TextColor3 = Color3.fromRGB(150, 150, 150)
                lbl.TextSize = 12
                lbl.Font = Enum.Font.GothamMedium
                lbl.TextXAlignment = Enum.TextXAlignment.Left
                lbl.Parent = TabPage
                
                local p = Instance.new("UIPadding", lbl)
                p.PaddingLeft = UDim.new(0, 15)
                
                return {
                    Set = function(new) lbl.Text = new end
                }
            end

            return Section
        end
        return Tab
    end
    return Window
end

return Alchemy
