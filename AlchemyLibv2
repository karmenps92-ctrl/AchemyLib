local Alchemy = {}
Alchemy.__index = Alchemy

-- Services
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

-- Global State
local ValidInstances = {}
local Connections = {}

-- Utility Functions
local function GetGuiParent()
    local ok, gui = pcall(function() return gethui and gethui() end)
    if ok and gui then return gui end
    local ok2, core = pcall(function() return CoreGui end)
    if ok2 and core then return core end
    return Players.LocalPlayer:WaitForChild("PlayerGui")
end

local function Tween(instance, properties, duration, style, direction)
    local info = TweenInfo.new(duration or 0.2, style or Enum.EasingStyle.Quad, direction or Enum.EasingDirection.Out)
    local tween = TweenService:Create(instance, info, properties)
    tween:Play()
    return tween
end

local function Round(instance, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or 6)
    corner.Parent = instance
    return corner
end

local function AddConnection(conn)
    table.insert(Connections, conn)
    return conn
end

-- Cleanup Method
function Alchemy:Destroy()
    print("[Alchemy Lib] Cleaning up active instances...")
    
    -- Disconnect global events
    for _, conn in ipairs(Connections) do
        if conn and typeof(conn) == "RBXScriptConnection" and conn.Connected then
            conn:Disconnect()
        end
    end
    table.clear(Connections)

    -- Destroy UI instances
    for _, instance in ipairs(ValidInstances) do
        if instance and instance.Parent then
            instance:Destroy()
        end
    end
    table.clear(ValidInstances)
end

-- Notification System
function Alchemy:Notify(options)
    options = options or {}
    local Title = options.Title or "Notification"
    local Content = options.Content or "This is a notification."
    local Duration = options.Duration or 6.5
    local Color = options.Color or Color3.fromRGB(170, 60, 255)

    -- Detect or Create Notification Container
    local NotifGui = GetGuiParent():FindFirstChild("AlchemyNotifications")
    if not NotifGui then
        NotifGui = Instance.new("ScreenGui")
        NotifGui.Name = "AlchemyNotifications"
        NotifGui.ResetOnSpawn = false
        NotifGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        NotifGui.Parent = GetGuiParent()
        table.insert(ValidInstances, NotifGui)

        local Container = Instance.new("Frame")
        Container.Name = "Container"
        Container.Size = UDim2.new(0, 300, 1, -20)
        Container.Position = UDim2.new(1, -320, 0, 20)
        Container.BackgroundTransparency = 1
        Container.Parent = NotifGui

        local ListLayout = Instance.new("UIListLayout")
        ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
        ListLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
        ListLayout.Padding = UDim.new(0, 10)
        ListLayout.Parent = Container
    end

    local Container = NotifGui.Container

    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(1, 0, 0, 0) -- Starts collapsed
    Frame.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
    Frame.BackgroundTransparency = 0
    Frame.ClipsDescendants = true
    Frame.Parent = Container
    Round(Frame, 10)

    local Stroke = Instance.new("UIStroke")
    Stroke.Color = Color
    Stroke.Thickness = 1
    Stroke.Transparency = 0.8
    Stroke.Parent = Frame

    local TitleLbl = Instance.new("TextLabel")
    TitleLbl.Size = UDim2.new(1, -20, 0, 25)
    TitleLbl.Position = UDim2.new(0, 10, 0, 5)
    TitleLbl.BackgroundTransparency = 1
    TitleLbl.Text = Title
    TitleLbl.TextColor3 = Color
    TitleLbl.TextSize = 14
    TitleLbl.Font = Enum.Font.GothamBold
    TitleLbl.TextXAlignment = Enum.TextXAlignment.Left
    TitleLbl.Parent = Frame

    local ContentLbl = Instance.new("TextLabel")
    ContentLbl.Size = UDim2.new(1, -20, 1, -35)
    ContentLbl.Position = UDim2.new(0, 10, 0, 30)
    ContentLbl.BackgroundTransparency = 1
    ContentLbl.Text = Content
    ContentLbl.TextColor3 = Color3.fromRGB(220, 220, 220)
    ContentLbl.TextSize = 12
    ContentLbl.Font = Enum.Font.Gotham
    ContentLbl.TextWrapped = true
    ContentLbl.TextXAlignment = Enum.TextXAlignment.Left
    ContentLbl.TextYAlignment = Enum.TextYAlignment.Top
    ContentLbl.Parent = Frame

    -- Calculate best size (approximate)
    local reqHeight = 40 + (string.len(Content) / 40) * 15
    if reqHeight < 70 then reqHeight = 70 end

    -- Animate In
    Tween(Frame, {Size = UDim2.new(1, 0, 0, reqHeight)}, 0.4, Enum.EasingStyle.Back)
    
    -- Lifetime handler
    task.spawn(function()
        task.wait(Duration)
        if Frame and Frame.Parent then
            Tween(Frame, {Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1}, 0.3)
            task.wait(0.3)
            Frame:Destroy()
        end
    end)
end

