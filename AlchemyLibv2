local Alchemy = {}
Alchemy.__index = Alchemy

-- Services
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

-- Global State
local ValidInstances = {}
local Connections = {}

-- Utility Functions
local function GetGuiParent()
    local ok, gui = pcall(function() return gethui and gethui() end)
    if ok and gui then return gui end
    local ok2, core = pcall(function() return CoreGui end)
    if ok2 and core then return core end
    return Players.LocalPlayer:WaitForChild("PlayerGui")
end

local function Tween(instance, properties, duration, style, direction)
    local info = TweenInfo.new(duration or 0.2, style or Enum.EasingStyle.Quad, direction or Enum.EasingDirection.Out)
    local tween = TweenService:Create(instance, info, properties)
    tween:Play()
    return tween
end

local function Round(instance, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or 6)
    corner.Parent = instance
    return corner
end

local function AddConnection(conn)
    table.insert(Connections, conn)
    return conn
end

-- Cleanup Method
function Alchemy:Destroy()
    print("[Alchemy Lib] Cleaning up active instances...")
    
    -- Disconnect global events
    for _, conn in ipairs(Connections) do
        if conn and typeof(conn) == "RBXScriptConnection" and conn.Connected then
            conn:Disconnect()
        end
    end
    table.clear(Connections)

    -- Destroy UI instances
    for _, instance in ipairs(ValidInstances) do
        if instance and instance.Parent then
            instance:Destroy()
        end
    end
    table.clear(ValidInstances)
end

-- Core Window Creation
function Alchemy:CreateWindow(options)
    options = options or {}
    local WindowName = options.Name or "Alchemy Hub"
    local WindowColor = options.Color or Color3.fromRGB(170, 60, 255)
    
    -- Library Object
    local Window = {
        Tabs = {},
        CurrentTab = nil,
        Color = WindowColor
    }
    setmetatable(Window, Alchemy)

    -- Security: Generate random name to prevent easy detection
    local SecretName = HttpService:GenerateGUID(false)

    -- Nuke previous instances from this library
    self:Destroy()

    -- GUI Construction
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = SecretName
    ScreenGui.ResetOnSpawn = false
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.Parent = GetGuiParent()
    table.insert(ValidInstances, ScreenGui)

    -- Glassmorphism Main Frame
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "Main"
    MainFrame.Size = UDim2.new(0, 600, 0, 420)
    MainFrame.Position = UDim2.new(0.5, -300, 0.5, -210)
    MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
    MainFrame.BackgroundTransparency = 0.15
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = true
    MainFrame.Parent = ScreenGui
    Round(MainFrame, 8)

    local Stroke = Instance.new("UIStroke")
    Stroke.Color = Color3.fromRGB(255, 255, 255)
    Stroke.Transparency = 0.85
    Stroke.Thickness = 1
    Stroke.Parent = MainFrame

    -- Dragging Logic
    local dragging, dragInput, dragStart, startPos
    AddConnection(MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end))

    AddConnection(MainFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end))

    AddConnection(UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end))

    -- Title Bar
    local TitleBar = Instance.new("Frame")
    TitleBar.Size = UDim2.new(1, 0, 0, 40)
    TitleBar.BackgroundTransparency = 1
    TitleBar.Parent = MainFrame

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Size = UDim2.new(1, -20, 1, 0)
    TitleLabel.Position = UDim2.new(0, 15, 0, 0)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = WindowName
    TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    TitleLabel.TextSize = 16
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    TitleLabel.Parent = TitleBar

    local TitleGlow = Instance.new("UIGradient")
    TitleGlow.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, WindowColor),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))
    })
    TitleGlow.Parent = TitleLabel

    -- Sidebar (Tabs)
    local Sidebar = Instance.new("Frame")
    Sidebar.Size = UDim2.new(0, 150, 1, -40)
    Sidebar.Position = UDim2.new(0, 0, 0, 40)
    Sidebar.BackgroundColor3 = Color3.fromRGB(10, 10, 15)
    Sidebar.BackgroundTransparency = 0.5
    Sidebar.BorderSizePixel = 0
    Sidebar.Parent = MainFrame

    local TabList = Instance.new("UIListLayout")
    TabList.SortOrder = Enum.SortOrder.LayoutOrder
    TabList.Padding = UDim.new(0, 5)
    TabList.Parent = Sidebar

    local SidebarPadding = Instance.new("UIPadding")
    SidebarPadding.PaddingTop = UDim.new(0, 10)
    SidebarPadding.PaddingLeft = UDim.new(0, 10)
    SidebarPadding.PaddingRight = UDim.new(0, 10)
    SidebarPadding.Parent = Sidebar

    -- Content Area
    local ContentContainer = Instance.new("Frame")
    ContentContainer.Size = UDim2.new(1, -150, 1, -40)
    ContentContainer.Position = UDim2.new(0, 150, 0, 40)
    ContentContainer.BackgroundTransparency = 1
    ContentContainer.Parent = MainFrame

    -- Methods for Window
    function Window:CreateTab(options)
        local TabName = options.Name or "Tab"
        
        local TabButton = Instance.new("TextButton")
        TabButton.Size = UDim2.new(1, 0, 0, 32)
        TabButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        TabButton.BackgroundTransparency = 0.95
        TabButton.Text = "  " .. TabName
        TabButton.TextColor3 = Color3.fromRGB(180, 180, 180)
        TabButton.TextSize = 13
        TabButton.Font = Enum.Font.GothamMedium
        TabButton.TextXAlignment = Enum.TextXAlignment.Left
        TabButton.Parent = Sidebar
        Round(TabButton, 6)

        local TabPage = Instance.new("ScrollingFrame")
        TabPage.Size = UDim2.new(1, 0, 1, 0)
        TabPage.BackgroundTransparency = 1
        TabPage.ScrollBarThickness = 2
        TabPage.ScrollBarImageColor3 = Window.Color
        TabPage.Visible = false
        TabPage.Parent = ContentContainer

        local PageList = Instance.new("UIListLayout")
        PageList.SortOrder = Enum.SortOrder.LayoutOrder
        PageList.Padding = UDim.new(0, 8)
        PageList.Parent = TabPage

        local PagePadding = Instance.new("UIPadding")
        PagePadding.PaddingTop = UDim.new(0, 10)
        PagePadding.PaddingLeft = UDim.new(0, 15)
        PagePadding.PaddingRight = UDim.new(0, 15)
        PagePadding.PaddingBottom = UDim.new(0, 10)
        PagePadding.Parent = TabPage

        AddConnection(PageList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            TabPage.CanvasSize = UDim2.new(0, 0, 0, PageList.AbsoluteContentSize.Y + 20)
        end))

        -- Tab Selection Logic
        AddConnection(TabButton.MouseButton1Click:Connect(function()
            for _, tab in pairs(Window.Tabs) do
                tab.Page.Visible = false
                Tween(tab.Button, {BackgroundTransparency = 0.95, TextColor3 = Color3.fromRGB(180, 180, 180)}, 0.2)
            end
            TabPage.Visible = true
            Tween(TabButton, {BackgroundTransparency = 0.8, TextColor3 = Window.Color}, 0.2)
            Window.CurrentTab = TabName
        end))

        -- Default selection
        if not Window.CurrentTab then
            TabPage.Visible = true
            TabButton.BackgroundTransparency = 0.8
            TabButton.TextColor3 = Window.Color
            Window.CurrentTab = TabName
        end

        local TabData = { Button = TabButton, Page = TabPage }
        table.insert(Window.Tabs, TabData)

        -- Section Class
        local Tab = {}
        function Tab:CreateSection(sectionName)
            local SectionLabel = Instance.new("TextLabel")
            SectionLabel.Size = UDim2.new(1, 0, 0, 20)
            SectionLabel.BackgroundTransparency = 1
            SectionLabel.Text = sectionName:upper()
            SectionLabel.TextColor3 = Window.Color
            SectionLabel.TextSize = 12
            SectionLabel.Font = Enum.Font.GothamBold
            SectionLabel.TextXAlignment = Enum.TextXAlignment.Left
            SectionLabel.Parent = TabPage

            local Section = {}
            
            function Section:CreateButton(opts)
                local btnName = opts.Name or "Button"
                local callback = opts.Callback or function() end

                local BtnFrame = Instance.new("TextButton")
                BtnFrame.Size = UDim2.new(1, 0, 0, 36)
                BtnFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
                BtnFrame.BackgroundTransparency = 0.4
                BtnFrame.Text = btnName
                BtnFrame.TextColor3 = Color3.fromRGB(220, 220, 220)
                BtnFrame.TextSize = 13
                BtnFrame.Font = Enum.Font.Gotham
                BtnFrame.Parent = TabPage
                Round(BtnFrame, 6)

                local s = Instance.new("UIStroke")
                s.Color = Color3.fromRGB(40, 40, 50)
                s.Parent = BtnFrame

                AddConnection(BtnFrame.MouseEnter:Connect(function()
                    Tween(BtnFrame, {BackgroundColor3 = Color3.fromRGB(30, 30, 35)}, 0.2)
                    Tween(s, {Color = Window.Color}, 0.2)
                end))
                AddConnection(BtnFrame.MouseLeave:Connect(function()
                    Tween(BtnFrame, {BackgroundColor3 = Color3.fromRGB(20, 20, 25)}, 0.2)
                    Tween(s, {Color = Color3.fromRGB(40, 40, 50)}, 0.2)
                end))

                AddConnection(BtnFrame.MouseButton1Click:Connect(function()
                    Tween(BtnFrame, {Size = UDim2.new(1, -4, 0, 32)}, 0.1)
                    task.wait(0.1)
                    Tween(BtnFrame, {Size = UDim2.new(1, 0, 0, 36)}, 0.1)
                    callback()
                end))
            end

            function Section:CreateToggle(opts)
                local tName = opts.Name or "Toggle"
                local state = opts.Default or false
                local callback = opts.Callback or function() end

                local TglHolder = Instance.new("Frame")
                TglHolder.Size = UDim2.new(1, 0, 0, 36)
                TglHolder.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
                TglHolder.BackgroundTransparency = 0.4
                TglHolder.Parent = TabPage
                Round(TglHolder, 6)

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -60, 1, 0)
                Label.Position = UDim2.new(0, 10, 0, 0)
                Label.BackgroundTransparency = 1
                Label.Text = tName
                Label.TextColor3 = Color3.fromRGB(220, 220, 220)
                Label.TextSize = 13
                Label.Font = Enum.Font.Gotham
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = TglHolder

                local SwitchBG = Instance.new("Frame")
                SwitchBG.Size = UDim2.new(0, 40, 0, 20)
                SwitchBG.Position = UDim2.new(1, -50, 0.5, -10)
                SwitchBG.BackgroundColor3 = state and Window.Color or Color3.fromRGB(40, 40, 50)
                SwitchBG.Parent = TglHolder
                Round(SwitchBG, 10)

                local Knob = Instance.new("Frame")
                Knob.Size = UDim2.new(0, 16, 0, 16)
                Knob.Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
                Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                Knob.Parent = SwitchBG
                Round(Knob, 8)

                local Btn = Instance.new("TextButton")
                Btn.Size = UDim2.new(1, 0, 1, 0)
                Btn.BackgroundTransparency = 1
                Btn.Text = ""
                Btn.Parent = TglHolder

                AddConnection(Btn.MouseButton1Click:Connect(function()
                    state = not state
                    Tween(SwitchBG, {BackgroundColor3 = state and Window.Color or Color3.fromRGB(40, 40, 50)}, 0.2)
                    Tween(Knob, {Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)}, 0.2, Enum.EasingStyle.Back)
                    callback(state)
                end))

                return {
                    Set = function(val)
                        state = val
                        Tween(SwitchBG, {BackgroundColor3 = state and Window.Color or Color3.fromRGB(40, 40, 50)}, 0.2)
                        Tween(Knob, {Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)}, 0.2, Enum.EasingStyle.Back)
                        callback(state)
                    end,
                    Get = function() return state end
                }
            end

            function Section:CreateSlider(opts)
                local sName = opts.Name or "Slider"
                local sMin = opts.Min or 0
                local sMax = opts.Max or 100
                local sDef = opts.Default or 50
                local callback = opts.Callback or function() end

                local SldrHolder = Instance.new("Frame")
                SldrHolder.Size = UDim2.new(1, 0, 0, 50)
                SldrHolder.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
                SldrHolder.BackgroundTransparency = 0.4
                SldrHolder.Parent = TabPage
                Round(SldrHolder, 6)

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -60, 0, 24)
                Label.Position = UDim2.new(0, 10, 0, 0)
                Label.BackgroundTransparency = 1
                Label.Text = sName
                Label.TextColor3 = Color3.fromRGB(220, 220, 220)
                Label.TextSize = 13
                Label.Font = Enum.Font.Gotham
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = SldrHolder

                local ValueLabel = Instance.new("TextLabel")
                ValueLabel.Size = UDim2.new(0, 50, 0, 24)
                ValueLabel.Position = UDim2.new(1, -60, 0, 0)
                ValueLabel.BackgroundTransparency = 1
                ValueLabel.Text = tostring(sDef)
                ValueLabel.TextColor3 = Window.Color
                ValueLabel.TextSize = 13
                ValueLabel.Font = Enum.Font.GothamBold
                ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
                ValueLabel.Parent = SldrHolder

                local TrackBG = Instance.new("Frame")
                TrackBG.Size = UDim2.new(1, -20, 0, 6)
                TrackBG.Position = UDim2.new(0, 10, 0, 32)
                TrackBG.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
                TrackBG.Parent = SldrHolder
                Round(TrackBG, 3)

                local Fill = Instance.new("Frame")
                local pct = math.clamp((sDef - sMin) / (sMax - sMin), 0, 1)
                Fill.Size = UDim2.new(pct, 0, 1, 0)
                Fill.BackgroundColor3 = Window.Color
                Fill.Parent = TrackBG
                Round(Fill, 3)

                local DragBtn = Instance.new("TextButton")
                DragBtn.Size = UDim2.new(1, 0, 1, 20)
                DragBtn.Position = UDim2.new(0, 0, 0, -10)
                DragBtn.BackgroundTransparency = 1
                DragBtn.Text = ""
                DragBtn.Parent = TrackBG

                local dragging = false
                AddConnection(DragBtn.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                    end
                end))

                AddConnection(UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                    end
                end))

                local function updateSlider(input)
                    local pos = math.clamp((input.Position.X - TrackBG.AbsolutePosition.X) / TrackBG.AbsoluteSize.X, 0, 1)
                    local value = math.floor(sMin + ((sMax - sMin) * pos))
                    Tween(Fill, {Size = UDim2.new(pos, 0, 1, 0)}, 0.1)
                    ValueLabel.Text = tostring(value)
                    callback(value)
                end

                AddConnection(UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        updateSlider(input)
                    end
                end))
            end
            
            function Section:CreateLabel(txt)
                local lbl = Instance.new("TextLabel")
                lbl.Size = UDim2.new(1, 0, 0, 20)
                lbl.BackgroundTransparency = 1
                lbl.Text = txt
                lbl.TextColor3 = Color3.fromRGB(150, 150, 150)
                lbl.TextSize = 12
                lbl.Font = Enum.Font.Gotham
                lbl.TextXAlignment = Enum.TextXAlignment.Left
                lbl.Parent = TabPage
            end

            return Section
        end
        return Tab
    end
    return Window
end

return Alchemy
